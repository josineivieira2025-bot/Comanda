generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  WAITER
  KITCHEN
  CASHIER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  ATTENTION
}

enum TabStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum OrderStatus {
  OPEN
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum KitchenSector {
  KITCHEN
  BAR
  GRILL
  DESSERT
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  VOUCHER
}

enum PaymentType {
  SALE
  WITHDRAWAL
  SUPPLY
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

model Restaurant {
  id String @id @default(cuid())
  name String
  slug String @unique
  city String?
  serviceFee Decimal @default(10) @db.Decimal(5,2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users User[]
  tables RestaurantTable[]
  tabs Tab[]
  products Product[]
  categories Category[]
  stockItems StockItem[]
  customers Customer[]
  cashSessions CashSession[]
  payments Payment[]
  @@map("restaurants")
}

model User {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  email String @unique
  passwordHash String @map("password_hash")
  role UserRole @default(WAITER)
  active Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tabs Tab[] @relation("WaiterTabs")
  orders Order[] @relation("WaiterOrders")
  stockMovements StockMovement[]
  openedCashSessions CashSession[] @relation("OpenedBy")
  closedCashSessions CashSession[] @relation("ClosedBy")
  payments Payment[]
  @@index([restaurantId])
  @@map("users")
}

model RestaurantTable {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  number String
  seats Int @default(4)
  status TableStatus @default(AVAILABLE)
  note String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tabs Tab[]
  calls ServiceCall[]
  @@unique([restaurantId,number])
  @@map("tables")
}

model Customer {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  phone String
  cpf String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tabs Tab[]
  @@index([restaurantId,phone])
  @@map("customers")
}

model Tab {
  id String @id @default(cuid())
  number Int @default(autoincrement())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  tableId String @map("table_id")
  table RestaurantTable @relation(fields:[tableId], references:[id])
  customerId String? @map("customer_id")
  customer Customer? @relation(fields:[customerId], references:[id])
  waiterId String? @map("waiter_id")
  waiter User? @relation("WaiterTabs", fields:[waiterId], references:[id])
  status TabStatus @default(OPEN)
  subtotal Decimal @default(0) @db.Decimal(12,2)
  serviceFee Decimal @default(0) @map("service_fee") @db.Decimal(12,2)
  total Decimal @default(0) @db.Decimal(12,2)
  openedAt DateTime @default(now()) @map("opened_at")
  closedAt DateTime? @map("closed_at")
  orders Order[]
  payments Payment[]
  @@index([restaurantId,status])
  @@map("tabs")
}

model Category {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  sector KitchenSector @default(KITCHEN)
  products Product[]
  @@unique([restaurantId,name])
  @@map("categories")
}

model Product {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  categoryId String @map("category_id")
  category Category @relation(fields:[categoryId], references:[id])
  name String
  description String?
  price Decimal @db.Decimal(12,2)
  imageUrl String? @map("image_url")
  available Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  orderItems OrderItem[]
  @@index([restaurantId,available])
  @@map("products")
}

model Order {
  id String @id @default(cuid())
  number Int @default(autoincrement())
  tabId String @map("tab_id")
  tab Tab @relation(fields:[tabId], references:[id], onDelete:Cascade)
  waiterId String? @map("waiter_id")
  waiter User? @relation("WaiterOrders", fields:[waiterId], references:[id])
  status OrderStatus @default(OPEN)
  note String?
  createdAt DateTime @default(now()) @map("created_at")
  startedAt DateTime? @map("started_at")
  readyAt DateTime? @map("ready_at")
  deliveredAt DateTime? @map("delivered_at")
  items OrderItem[]
  @@index([status,createdAt])
  @@map("orders")
}

model OrderItem {
  id String @id @default(cuid())
  orderId String @map("order_id")
  order Order @relation(fields:[orderId], references:[id], onDelete:Cascade)
  productId String @map("product_id")
  product Product @relation(fields:[productId], references:[id])
  quantity Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12,2)
  note String?
  @@map("order_items")
}

model StockItem {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  category String
  unit String
  quantity Decimal @default(0) @db.Decimal(12,3)
  minimumStock Decimal @default(0) @map("minimum_stock") @db.Decimal(12,3)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  movements StockMovement[]
  @@index([restaurantId])
  @@map("stock_items")
}

model StockMovement {
  id String @id @default(cuid())
  stockItemId String @map("stock_item_id")
  stockItem StockItem @relation(fields:[stockItemId], references:[id], onDelete:Cascade)
  userId String @map("user_id")
  user User @relation(fields:[userId], references:[id])
  type StockMovementType
  quantity Decimal @db.Decimal(12,3)
  reason String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("stock_movements")
}

model CashSession {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  openedById String @map("opened_by_id")
  openedBy User @relation("OpenedBy", fields:[openedById], references:[id])
  closedById String? @map("closed_by_id")
  closedBy User? @relation("ClosedBy", fields:[closedById], references:[id])
  openingAmount Decimal @map("opening_amount") @db.Decimal(12,2)
  closingAmount Decimal? @map("closing_amount") @db.Decimal(12,2)
  status CashSessionStatus @default(OPEN)
  openedAt DateTime @default(now()) @map("opened_at")
  closedAt DateTime? @map("closed_at")
  payments Payment[]
  @@index([restaurantId,status])
  @@map("cash_sessions")
}

model Payment {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  tabId String? @map("tab_id")
  tab Tab? @relation(fields:[tabId], references:[id])
  cashSessionId String? @map("cash_session_id")
  cashSession CashSession? @relation(fields:[cashSessionId], references:[id])
  userId String @map("user_id")
  user User @relation(fields:[userId], references:[id])
  type PaymentType @default(SALE)
  method PaymentMethod
  amount Decimal @db.Decimal(12,2)
  description String?
  createdAt DateTime @default(now()) @map("created_at")
  @@index([restaurantId,createdAt])
  @@map("payments")
}

model ServiceCall {
  id String @id @default(cuid())
  tableId String @map("table_id")
  table RestaurantTable @relation(fields:[tableId], references:[id], onDelete:Cascade)
  type String
  status String @default("OPEN")
  createdAt DateTime @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")
  @@map("service_calls")
}
