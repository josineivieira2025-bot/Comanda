generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  WAITER
  KITCHEN
  CASHIER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  ATTENTION
}

enum TabStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum OrderStatus {
  OPEN
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum KitchenSector {
  KITCHEN
  BAR
  GRILL
  DESSERT
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  VOUCHER
}

enum PaymentType {
  SALE
  WITHDRAWAL
  SUPPLY
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum FiscalEnvironment {
  HOMOLOGATION
  PRODUCTION
}

enum FiscalDocumentStatus {
  NEEDS_CONFIGURATION
  PENDING
  AUTHORIZED
  REJECTED
  CANCELLED
}

enum IntegrationProvider {
  IFOOD
}

enum IntegrationStatus {
  DISABLED
  CONFIGURED
  CONNECTED
  ERROR
}

enum DeliveryStatus {
  WAITING
  ASSIGNED
  PICKED_UP
  DELIVERED
  CANCELLED
}

model Restaurant {
  id String @id @default(cuid())
  name String
  slug String @unique
  city String?
  logoUrl String? @map("logo_url")
  serviceFee Decimal @default(10) @db.Decimal(5,2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users User[]
  tables RestaurantTable[]
  tabs Tab[]
  products Product[]
  categories Category[]
  stockItems StockItem[]
  customers Customer[]
  cashSessions CashSession[]
  payments Payment[]
  commandCards CommandCard[]
  fiscalSettings FiscalSettings?
  integrations IntegrationSetting[]
  fiscalDocuments FiscalDocument[]
  couriers Courier[]
  deliveryOrders DeliveryOrder[]
  @@map("restaurants")
}

model User {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  email String @unique
  passwordHash String @map("password_hash")
  role UserRole @default(WAITER)
  permissions String[] @default([])
  active Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tabs Tab[] @relation("WaiterTabs")
  orders Order[] @relation("WaiterOrders")
  stockMovements StockMovement[]
  openedCashSessions CashSession[] @relation("OpenedBy")
  closedCashSessions CashSession[] @relation("ClosedBy")
  payments Payment[]
  @@index([restaurantId])
  @@map("users")
}

model RestaurantTable {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  number String
  seats Int @default(4)
  status TableStatus @default(AVAILABLE)
  note String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tabs Tab[]
  deliveryOrders Order[] @relation("OrderDeliveryTable")
  calls ServiceCall[]
  @@unique([restaurantId,number])
  @@map("tables")
}

model CommandCard {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  number Int
  active Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tabs Tab[]
  @@unique([restaurantId,number])
  @@index([restaurantId,active])
  @@map("command_cards")
}

model Customer {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  phone String
  cpf String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tabs Tab[]
  @@index([restaurantId,phone])
  @@map("customers")
}

model Tab {
  id String @id @default(cuid())
  number Int @default(autoincrement())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  tableId String @map("table_id")
  table RestaurantTable @relation(fields:[tableId], references:[id])
  customerId String? @map("customer_id")
  customer Customer? @relation(fields:[customerId], references:[id])
  waiterId String? @map("waiter_id")
  waiter User? @relation("WaiterTabs", fields:[waiterId], references:[id])
  commandCardId String? @map("command_card_id")
  commandCard CommandCard? @relation(fields:[commandCardId], references:[id])
  status TabStatus @default(OPEN)
  subtotal Decimal @default(0) @db.Decimal(12,2)
  serviceFee Decimal @default(0) @map("service_fee") @db.Decimal(12,2)
  total Decimal @default(0) @db.Decimal(12,2)
  openedAt DateTime @default(now()) @map("opened_at")
  closedAt DateTime? @map("closed_at")
  orders Order[]
  payments Payment[]
  fiscalDocuments FiscalDocument[]
  @@index([restaurantId,status])
  @@map("tabs")
}

model Category {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  sector KitchenSector @default(KITCHEN)
  products Product[]
  @@unique([restaurantId,name])
  @@map("categories")
}

model Product {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  categoryId String @map("category_id")
  category Category @relation(fields:[categoryId], references:[id])
  name String
  description String?
  price Decimal @db.Decimal(12,2)
  imageUrl String? @map("image_url")
  available Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  orderItems OrderItem[]
  @@index([restaurantId,available])
  @@map("products")
}

model Order {
  id String @id @default(cuid())
  number Int @default(autoincrement())
  tabId String @map("tab_id")
  tab Tab @relation(fields:[tabId], references:[id], onDelete:Cascade)
  deliveryTableId String? @map("delivery_table_id")
  deliveryTable RestaurantTable? @relation("OrderDeliveryTable", fields:[deliveryTableId], references:[id])
  waiterId String? @map("waiter_id")
  waiter User? @relation("WaiterOrders", fields:[waiterId], references:[id])
  status OrderStatus @default(OPEN)
  note String?
  createdAt DateTime @default(now()) @map("created_at")
  startedAt DateTime? @map("started_at")
  readyAt DateTime? @map("ready_at")
  deliveredAt DateTime? @map("delivered_at")
  items OrderItem[]
  deliveries DeliveryOrder[]
  @@index([status,createdAt])
  @@index([deliveryTableId])
  @@map("orders")
}

model OrderItem {
  id String @id @default(cuid())
  orderId String @map("order_id")
  order Order @relation(fields:[orderId], references:[id], onDelete:Cascade)
  productId String @map("product_id")
  product Product @relation(fields:[productId], references:[id])
  quantity Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12,2)
  note String?
  @@map("order_items")
}

model StockItem {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  category String
  unit String
  quantity Decimal @default(0) @db.Decimal(12,3)
  minimumStock Decimal @default(0) @map("minimum_stock") @db.Decimal(12,3)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  movements StockMovement[]
  @@index([restaurantId])
  @@map("stock_items")
}

model StockMovement {
  id String @id @default(cuid())
  stockItemId String @map("stock_item_id")
  stockItem StockItem @relation(fields:[stockItemId], references:[id], onDelete:Cascade)
  userId String @map("user_id")
  user User @relation(fields:[userId], references:[id])
  type StockMovementType
  quantity Decimal @db.Decimal(12,3)
  reason String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("stock_movements")
}

model CashSession {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  openedById String @map("opened_by_id")
  openedBy User @relation("OpenedBy", fields:[openedById], references:[id])
  closedById String? @map("closed_by_id")
  closedBy User? @relation("ClosedBy", fields:[closedById], references:[id])
  openingAmount Decimal @map("opening_amount") @db.Decimal(12,2)
  closingAmount Decimal? @map("closing_amount") @db.Decimal(12,2)
  status CashSessionStatus @default(OPEN)
  openedAt DateTime @default(now()) @map("opened_at")
  closedAt DateTime? @map("closed_at")
  payments Payment[]
  @@index([restaurantId,status])
  @@map("cash_sessions")
}

model Payment {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  tabId String? @map("tab_id")
  tab Tab? @relation(fields:[tabId], references:[id])
  cashSessionId String? @map("cash_session_id")
  cashSession CashSession? @relation(fields:[cashSessionId], references:[id])
  userId String @map("user_id")
  user User @relation(fields:[userId], references:[id])
  type PaymentType @default(SALE)
  method PaymentMethod
  amount Decimal @db.Decimal(12,2)
  description String?
  createdAt DateTime @default(now()) @map("created_at")
  fiscalDocument FiscalDocument?
  @@index([restaurantId,createdAt])
  @@map("payments")
}

model FiscalSettings {
  id String @id @default(cuid())
  restaurantId String @unique @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  enabled Boolean @default(false)
  autoIssueCupom Boolean @default(true) @map("auto_issue_cupom")
  environment FiscalEnvironment @default(HOMOLOGATION)
  provider String @default("manual")
  providerToken String? @map("provider_token")
  certificateName String? @map("certificate_name")
  certificateExpiresAt DateTime? @map("certificate_expires_at")
  cnpj String?
  legalName String? @map("legal_name")
  tradeName String? @map("trade_name")
  stateRegistration String? @map("state_registration")
  municipalRegistration String? @map("municipal_registration")
  taxRegime String? @map("tax_regime")
  cep String?
  street String?
  number String?
  neighborhood String?
  city String?
  state String?
  nfceSeries Int @default(1) @map("nfce_series")
  nfceNextNumber Int @default(1) @map("nfce_next_number")
  nfeSeries Int @default(1) @map("nfe_series")
  nfeNextNumber Int @default(1) @map("nfe_next_number")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("fiscal_settings")
}

model IntegrationSetting {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  provider IntegrationProvider
  enabled Boolean @default(false)
  status IntegrationStatus @default(DISABLED)
  storeId String? @map("store_id")
  merchantId String? @map("merchant_id")
  accessToken String? @map("access_token")
  refreshToken String? @map("refresh_token")
  webhookSecret String? @map("webhook_secret")
  lastSyncAt DateTime? @map("last_sync_at")
  lastError String? @map("last_error")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@unique([restaurantId,provider])
  @@map("integration_settings")
}

model Courier {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  name String
  phone String
  vehicle String?
  plate String?
  active Boolean @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deliveries DeliveryOrder[]
  @@index([restaurantId,active])
  @@map("couriers")
}

model DeliveryOrder {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  orderId String? @map("order_id")
  order Order? @relation(fields:[orderId], references:[id], onDelete:SetNull)
  courierId String? @map("courier_id")
  courier Courier? @relation(fields:[courierId], references:[id], onDelete:SetNull)
  externalProvider IntegrationProvider? @map("external_provider")
  externalId String? @map("external_id")
  customerName String @map("customer_name")
  customerPhone String? @map("customer_phone")
  address String
  neighborhood String?
  city String?
  state String?
  amount Decimal @default(0) @db.Decimal(12,2)
  deliveryFee Decimal @default(0) @map("delivery_fee") @db.Decimal(12,2)
  status DeliveryStatus @default(WAITING)
  notes String?
  createdAt DateTime @default(now()) @map("created_at")
  assignedAt DateTime? @map("assigned_at")
  pickedUpAt DateTime? @map("picked_up_at")
  deliveredAt DateTime? @map("delivered_at")
  cancelledAt DateTime? @map("cancelled_at")
  @@index([restaurantId,status])
  @@unique([restaurantId,externalProvider,externalId])
  @@map("delivery_orders")
}

model FiscalDocument {
  id String @id @default(cuid())
  restaurantId String @map("restaurant_id")
  restaurant Restaurant @relation(fields:[restaurantId], references:[id], onDelete:Cascade)
  paymentId String? @unique @map("payment_id")
  payment Payment? @relation(fields:[paymentId], references:[id], onDelete:SetNull)
  tabId String? @map("tab_id")
  tab Tab? @relation(fields:[tabId], references:[id], onDelete:SetNull)
  type String @default("NFC_E")
  status FiscalDocumentStatus @default(NEEDS_CONFIGURATION)
  environment FiscalEnvironment @default(HOMOLOGATION)
  series Int?
  number Int?
  accessKey String? @map("access_key")
  protocol String?
  xmlUrl String? @map("xml_url")
  danfeUrl String? @map("danfe_url")
  errorMessage String? @map("error_message")
  amount Decimal @db.Decimal(12,2)
  customerCpf String? @map("customer_cpf")
  issuedAt DateTime? @map("issued_at")
  cancelledAt DateTime? @map("cancelled_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([restaurantId,status,createdAt])
  @@map("fiscal_documents")
}

model ServiceCall {
  id String @id @default(cuid())
  tableId String @map("table_id")
  table RestaurantTable @relation(fields:[tableId], references:[id], onDelete:Cascade)
  type String
  status String @default("OPEN")
  createdAt DateTime @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")
  @@map("service_calls")
}
